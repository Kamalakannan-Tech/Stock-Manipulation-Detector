# Stock Manipulation Detection - Environment Configuration

# ======================
# API CREDENTIALS
# ======================

# Twitter API (Optional - requires paid plan)
# Get from: https://developer.twitter.com/
TWITTER_BEARER_TOKEN=

# Reddit API (Optional)
# Get from: https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=StockManipulationDetector/1.0

# StockTwits (Optional - public API available)
STOCKTWITS_TOKEN=

# Alpaca Market Data (Optional - free tier has limits)
# Get from: https://alpaca.markets/
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ======================
# DATABASE
# ======================
MONGO_URI=mongodb://localhost:27017/
MONGO_DB=stock_manipulation
REDIS_URL=redis://localhost:6379

# ======================
# APPLICATION SETTINGS
# ======================

# Stocks to monitor (comma-separated)
MONITORED_TICKERS=GME,AMC,TSLA,AAPL,MSFT,NVDA

# Model settings
MODEL_PATH=models/saved_models/best_model.pth
DEVICE=cpu

# Flask settings
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=dev-secret-key-change-in-production

# ======================
# NOTES
# ======================
# 
# RUNNING WITHOUT API CREDENTIALS:
# - The system will work in "demo mode" without live data
# - It will use rule-based analysis instead of real-time feeds
# - Perfect for testing and development
#
# TO GET API CREDENTIALS:
# 1. Twitter: https://developer.twitter.com/ (requires paid plan)
# 2. Reddit: https://www.reddit.com/prefs/apps (free)
# 3. Alpaca: https://alpaca.markets/ (free tier available)
# 4. StockTwits: Public API available without token
#
